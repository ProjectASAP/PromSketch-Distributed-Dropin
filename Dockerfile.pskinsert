# Build stage
FROM golang:1.25-alpine AS builder

RUN apk add --no-cache gcc musl-dev git

WORKDIR /build

COPY go.mod go.sum ./
RUN go mod download

COPY . .

RUN CGO_ENABLED=0 GOOS=linux go build -trimpath -o /build/bin/pskinsert ./cmd/pskinsert

# Runtime stage
FROM alpine:3.19

RUN apk add --no-cache ca-certificates tzdata

COPY --from=builder /build/bin/pskinsert /usr/local/bin/pskinsert

EXPOSE 8480

ENTRYPOINT ["/usr/local/bin/pskinsert"]
