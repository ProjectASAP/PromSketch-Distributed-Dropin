{
  "uid": "promsketch-e2e",
  "title": "PromSketch E2E - Quantile Comparison",
  "tags": ["promsketch", "e2e"],
  "timezone": "browser",
  "refresh": "10s",
  "time": {
    "from": "now-15m",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "title": "Quantile p95 — PromSketch vs VictoriaMetrics",
      "type": "timeseries",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "auto"
          },
          "unit": "short"
        },
        "overrides": [
          {
            "matcher": { "id": "byFrameRefID", "options": "A" },
            "properties": [
              { "id": "displayName", "value": "PromSketch (sketch)" },
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "blue" } }
            ]
          },
          {
            "matcher": { "id": "byFrameRefID", "options": "B" },
            "properties": [
              { "id": "displayName", "value": "VictoriaMetrics (exact)" },
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "orange" } }
            ]
          }
        ]
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "promsketch-dashboard" },
          "expr": "quantile_over_time(0.95, fake_machine_metric[5m])",
          "legendFormat": "PromSketch p95"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "victoriametrics-dashboard" },
          "expr": "quantile_over_time(0.95, fake_machine_metric[5m])",
          "legendFormat": "VictoriaMetrics p95"
        }
      ]
    },
    {
      "id": 2,
      "title": "Quantile p50 — PromSketch vs VictoriaMetrics",
      "type": "timeseries",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 10 },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "auto"
          },
          "unit": "short"
        },
        "overrides": [
          {
            "matcher": { "id": "byFrameRefID", "options": "A" },
            "properties": [
              { "id": "displayName", "value": "PromSketch (sketch)" },
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "blue" } }
            ]
          },
          {
            "matcher": { "id": "byFrameRefID", "options": "B" },
            "properties": [
              { "id": "displayName", "value": "VictoriaMetrics (exact)" },
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "orange" } }
            ]
          }
        ]
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "promsketch-dashboard" },
          "expr": "quantile_over_time(0.5, fake_machine_metric[5m])",
          "legendFormat": "PromSketch p50"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "victoriametrics-dashboard" },
          "expr": "quantile_over_time(0.5, fake_machine_metric[5m])",
          "legendFormat": "VictoriaMetrics p50"
        }
      ]
    },
    {
      "id": 3,
      "title": "Series in VictoriaMetrics",
      "type": "stat",
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 20 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "victoriametrics-dashboard" },
          "expr": "count(fake_machine_metric)",
          "legendFormat": "fake_machine_metric series in VM",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "area"
      }
    },
    {
      "id": 7,
      "title": "Series in PromSketch",
      "type": "stat",
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 20 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "blue", "value": 1 }
            ]
          }
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "promsketch-dashboard" },
          "expr": "count(fake_machine_metric)",
          "legendFormat": "fake_machine_metric series in PromSketch",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "area"
      }
    },
    {
      "id": 4,
      "title": "Scrape Rate (samples/scrape)",
      "type": "stat",
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 20 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "victoriametrics-dashboard" },
          "expr": "scrape_samples_scraped{job=\"fake-exporter\"}",
          "legendFormat": "samples/scrape",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "area"
      }
    },
    {
      "id": 8,
      "title": "Query Latency — PromSketch vs VictoriaMetrics",
      "type": "timeseries",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 26 },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "auto"
          },
          "unit": "s"
        },
        "overrides": [
          {
            "matcher": { "id": "byFrameRefID", "options": "A" },
            "properties": [
              { "id": "displayName", "value": "PromSketch p50" },
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "blue" } }
            ]
          },
          {
            "matcher": { "id": "byFrameRefID", "options": "B" },
            "properties": [
              { "id": "displayName", "value": "PromSketch p90" },
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "light-blue" } }
            ]
          },
          {
            "matcher": { "id": "byFrameRefID", "options": "C" },
            "properties": [
              { "id": "displayName", "value": "PromSketch p99" },
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "super-light-blue" } }
            ]
          },
          {
            "matcher": { "id": "byFrameRefID", "options": "D" },
            "properties": [
              { "id": "displayName", "value": "VictoriaMetrics p50" },
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "orange" } }
            ]
          },
          {
            "matcher": { "id": "byFrameRefID", "options": "E" },
            "properties": [
              { "id": "displayName", "value": "VictoriaMetrics p90" },
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "light-orange" } }
            ]
          },
          {
            "matcher": { "id": "byFrameRefID", "options": "F" },
            "properties": [
              { "id": "displayName", "value": "VictoriaMetrics p99" },
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "super-light-orange" } }
            ]
          }
        ]
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "victoriametrics-dashboard" },
          "expr": "histogram_quantile(0.50, sum by (le) (rate(promsketch_query_duration_seconds_bucket[5m])))",
          "legendFormat": "PromSketch p50"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "victoriametrics-dashboard" },
          "expr": "histogram_quantile(0.90, sum by (le) (rate(promsketch_query_duration_seconds_bucket[5m])))",
          "legendFormat": "PromSketch p90"
        },
        {
          "refId": "C",
          "datasource": { "type": "prometheus", "uid": "victoriametrics-dashboard" },
          "expr": "histogram_quantile(0.99, sum by (le) (rate(promsketch_query_duration_seconds_bucket[5m])))",
          "legendFormat": "PromSketch p99"
        },
        {
          "refId": "D",
          "datasource": { "type": "prometheus", "uid": "victoriametrics-dashboard" },
          "expr": "vm_request_duration_seconds{path=\"/api/v1/query_range\", quantile=\"0.5\"}",
          "legendFormat": "VictoriaMetrics p50"
        },
        {
          "refId": "E",
          "datasource": { "type": "prometheus", "uid": "victoriametrics-dashboard" },
          "expr": "vm_request_duration_seconds{path=\"/api/v1/query_range\", quantile=\"0.9\"}",
          "legendFormat": "VictoriaMetrics p90"
        },
        {
          "refId": "F",
          "datasource": { "type": "prometheus", "uid": "victoriametrics-dashboard" },
          "expr": "vm_request_duration_seconds{path=\"/api/v1/query_range\", quantile=\"0.99\"}",
          "legendFormat": "VictoriaMetrics p99"
        }
      ]
    },
